generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Subject {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("subjects")
}

model Exercise {
  id            String       @id @default(uuid())
  subject       String
  questionCount Int          @map("question_count")
  questionType  String       @map("question_type")
  difficulty    String
  instructions  String?
  status        String       @default("draft")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  questions     Question[]
  shareLinks    ShareLink[]
  submissions   Submission[]

  @@map("exercises")
}

model Question {
  id            String       @id @default(uuid())
  exerciseId    String       @map("exercise_id")
  orderIndex    Int          @map("order_index")
  type          String
  questionText  String       @map("question_text")
  options       String?      // JSON array for MCQ
  correctAnswer String?      @map("correct_answer")
  points        Int          @default(1)
  createdAt     DateTime     @default(now()) @map("created_at")
  exercise      Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  answers       Answer[]

  @@index([exerciseId, orderIndex])
  @@map("questions")
}

model ShareLink {
  id          String       @id @default(uuid())
  exerciseId  String       @map("exercise_id")
  code        String       @unique
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  expiresAt   DateTime?    @map("expires_at")
  exercise    Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([code])
  @@index([exerciseId])
  @@map("share_links")
}

model Submission {
  id           String       @id @default(uuid())
  exerciseId   String       @map("exercise_id")
  shareLinkId  String?      @map("share_link_id")
  studentName  String?      @map("student_name")
  status       String       @default("submitted")
  totalScore   Float?       @map("total_score")
  maxScore     Float?       @map("max_score")
  submittedAt  DateTime     @default(now()) @map("submitted_at")
  correctedAt  DateTime?    @map("corrected_at")
  exercise     Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  shareLink    ShareLink?   @relation(fields: [shareLinkId], references: [id], onDelete: SetNull)
  answers      Answer[]

  @@index([exerciseId])
  @@index([shareLinkId])
  @@map("submissions")
}

model Answer {
  id            String     @id @default(uuid())
  submissionId  String     @map("submission_id")
  questionId    String     @map("question_id")
  studentAnswer String?    @map("student_answer")
  isCorrect     Boolean?   @map("is_correct")
  score         Float?
  maxScore      Float?     @map("max_score")
  feedback      String?
  createdAt     DateTime   @default(now()) @map("created_at")
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question      Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([questionId])
  @@map("answers")
}
